<view class="page">
  <view class="card hero-card">
    <image class="hero-image" src="{{heroImage}}" mode="aspectFill" />
    <view class="section-title">活动资讯</view>
    <view class="section-subtitle">持续更新讲解专场、夜游体验、亲子研学与风物活动信息</view>
  </view>

  <view class="category-list">
    <block wx:for="{{categories}}" wx:key="*this">
      <view class="category-chip {{activeCategory === item ? 'category-chip-active' : ''}}" bindtap="switchCategory" data-category="{{item}}">
        {{item}}
      </view>
    </block>
  </view>

  <block wx:for="{{activityNews}}" wx:key="id">
    <view class="card activity-card">
      <image class="activity-image" src="{{item.image}}" mode="aspectFill" bindtap="previewPoster" data-image="{{item.image}}" />
      <view class="row-between">
        <view class="activity-title">{{item.title}}</view>
        <view class="activity-status">{{item.status}}</view>
      </view>
      <view class="activity-summary">{{item.summary}}</view>
      <view class="activity-meta">{{item.date}} · {{item.place}}</view>
      <view class="activity-meta">类别：{{item.category}} · 剩余名额：{{item.remaining}}</view>
      <view class="action-row action-row-narrow">
        <view class="ghost-button half-button">{{item.enrolled}} / {{item.capacity}} 已参与</view>
        <view class="button-primary half-button" bindtap="register" data-id="{{item.id}}">
          {{item.registered ? '已报名' : '立即报名'}}
        </view>
      </view>
    </view>
  </block>

  <view class="card service-card">
    <view class="section-title">参与建议</view>
    <view class="service-copy">建议游客先在导览页规划路线，再根据时段选择活动；如需统一查看常用入口，可进入我的页面。</view>
    <view class="action-row">
      <view class="button-primary half-button" bindtap="openGuide">去看导览</view>
      <view class="ghost-button half-button" bindtap="openProfile">进入我的</view>
    </view>
  </view>
</view>
