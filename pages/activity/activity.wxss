@keyframes skeletonShimmer {
  0% { opacity: 0.4; }
  50% { opacity: 0.8; }
  100% { opacity: 0.4; }
}

.skeleton-block {
  background: #e8e0d6;
  border-radius: 12rpx;
  animation: skeletonShimmer 1.5s ease-in-out infinite;
}

.hero-card,
.service-card {
  margin-top: 18rpx;
}

.hero-card {
  background: linear-gradient(135deg, #efe0d2, #f9f5f0);
  overflow: hidden;
  margin-top: 0;
}

.hero-image,
.activity-image {
  display: block;
}

.hero-image {
  height: 300rpx;
}

.activity-image {
  height: 230rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #35271f;
}

.activity-status {
  font-size: 24rpx;
  color: #a05732;
}

.activity-summary,
.activity-meta,
.service-copy {
  margin-top: 14rpx;
  line-height: 1.7;
  color: #6d6156;
}

.category-chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #f3e6dc;
  color: #8f5231;
  font-size: 24rpx;
}

.category-chip-active {
  background: #9c5230;
  color: #fff;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.action-row-narrow {
  margin-top: 18rpx;
}

.half-button {
  flex: 1;
}

.ghost-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 26rpx;
  border-radius: 999rpx;
  background: #f3e8de;
  color: #91492b;
  font-size: 26rpx;
}
