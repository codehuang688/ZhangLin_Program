/* ===== 沉浸式Banner ===== */
.hero-banner {
  position: relative;
  height: 480rpx;
  overflow: hidden;
  margin: -20rpx -24rpx 0;
}

.hero-bg {
  position: absolute;
  top: -10%;
  left: 0;
  width: 100%;
  height: 120%;
  display: block;
}

.hero-veil {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(30,15,5,0.5) 0%, rgba(55,30,12,0.65) 40%, rgba(80,45,22,0.85) 100%);
}

.hero-steam {
  position: absolute;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
  pointer-events: none;
}

.steam {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 240, 210, 0.25), transparent 70%);
}

.s1 { left: -80rpx; bottom: 0; animation: steamRise 4s ease-out infinite; }
.s2 { left: 0; bottom: 10rpx; animation: steamRise 5s ease-out 0.6s infinite; }
.s3 { left: 80rpx; bottom: 5rpx; animation: steamRise 3.5s ease-out 1.2s infinite; }

@keyframes steamRise {
  0% { transform: translateY(0) scale(0.8); opacity: 0; }
  30% { opacity: 0.6; }
  60% { opacity: 0.4; }
  100% { transform: translateY(-60rpx) scale(2); opacity: 0; }
}

.hero-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 36rpx 44rpx;
  z-index: 2;
}

.hero-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  background: rgba(200, 150, 80, 0.15);
  border: 1rpx solid rgba(220, 180, 110, 0.3);
  color: rgba(240, 210, 150, 0.9);
  font-size: 20rpx;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}

.hero-headline {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.5);
}

.hero-tagline {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: rgba(240, 210, 160, 0.85);
  font-weight: 300;
  letter-spacing: 8rpx;
}

.hero-desc-text {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: rgba(200, 180, 140, 0.6);
  line-height: 1.6;
}

/* ===== AI 风物推荐 ===== */
.ai-tip-card {
  background: linear-gradient(135deg, rgba(60, 30, 10, 0.93), rgba(80, 45, 20, 0.9));
  border: 1rpx solid rgba(200, 160, 100, 0.15);
  position: relative;
  overflow: hidden;
}

.ai-tip-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(220, 170, 90, 0.08), transparent);
}

.ai-tip-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ai-tip-label {
  font-size: 22rpx;
  color: rgba(220, 190, 150, 0.85);
  font-weight: 600;
}

.ai-tip-body {
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.ai-tip-icon { font-size: 32rpx; flex-shrink: 0; line-height: 1.4; }

.ai-tip-text {
  font-size: 24rpx;
  color: rgba(240, 215, 180, 0.75);
  line-height: 1.7;
}

/* ===== 今日味道横滑 ===== */
.today-scroll { white-space: nowrap; margin-top: 20rpx; }
.today-track { display: inline-flex; gap: 16rpx; padding: 4rpx 4rpx 12rpx; }

.today-card {
  width: 280rpx;
  height: 200rpx;
  border-radius: var(--radius-card);
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.today-img { width: 100%; height: 100%; }

.today-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 18rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
}

.today-hot {
  font-size: 20rpx;
  color: rgba(255, 200, 100, 0.9);
  margin-bottom: 4rpx;
}

.today-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  white-space: normal;
  line-height: 1.3;
}

/* ===== 分类标签 ===== */
.category-scroll { white-space: nowrap; margin-top: 16rpx; }
.category-wrap { display: inline-flex; gap: 14rpx; padding: 0 4rpx; }

.cat-chip {
  padding: 14rpx 26rpx;
  border-radius: var(--radius-full);
  background: #fdf3e3;
  color: #8a5a35;
  font-size: 24rpx;
  white-space: nowrap;
}

.cat-chip-active {
  background: linear-gradient(135deg, #b26a1e, #c87a2e);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(178, 106, 30, 0.3);
}

/* ===== 风物大图卡片 ===== */
.specialty-card {
  padding: 0;
  margin-bottom: 20rpx;
  background: #fff;
}

.specialty-img {
  width: 100%;
  height: 260rpx;
  display: block;
  border-radius: var(--radius-card) var(--radius-card) 0 0;
}

.specialty-body {
  padding: 28rpx;
}

.specialty-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #3c2c20;
}

.specialty-cat {
  font-size: 22rpx;
  color: #b26a1e;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  background: rgba(178, 106, 30, 0.08);
}

.specialty-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #5a4a3a;
  line-height: 1.7;
}

.specialty-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: #8a7562;
}

.meta-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #b26a1e;
}

.meta-icon-sm { font-size: 20rpx; }

.story-link {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(178, 106, 30, 0.1);
  font-size: 22rpx;
  color: #b26a1e;
  text-align: center;
}

/* ===== 风物故事弹窗 ===== */
.story-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.story-mask.show { opacity: 1; pointer-events: auto; }

.story-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 70vh;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  display: flex;
  flex-direction: column;
}

.story-panel.show { transform: translateY(0); }

.story-panel-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 0 28rpx 28rpx;
}

.story-panel-handle {
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #d4c5b0;
  margin: 16rpx auto;
}

.story-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx 16rpx;
}

.story-panel-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #3c2c20;
}

.story-panel-close {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f5f0e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #8a6a4d;
}

.story-panel-img {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  display: block;
  margin-bottom: 20rpx;
}

.story-panel-body {
  padding: 0 28rpx;
  font-size: 24rpx;
  color: #5a4a3a;
  line-height: 1.9;
}

.story-panel-footer {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
  font-size: 20rpx;
  color: #9a7b5f;
}

/* ===== 页脚 ===== */
.page-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx 0 calc(160rpx + env(safe-area-inset-bottom));
}

.footer-line {
  width: 40rpx;
  height: 1rpx;
  background: rgba(178, 106, 30, 0.2);
}

.footer-text {
  font-size: 20rpx;
  color: rgba(178, 106, 30, 0.4);
  letter-spacing: 4rpx;
}