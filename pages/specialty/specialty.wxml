<view class="page">
  <view class="card intro-card">
    <view class="section-title">本土特色风物</view>
    <view class="section-subtitle">把游客的“看景”延伸到“尝味、选礼、感受地方生活”</view>
  </view>

  <view class="category-list">
    <block wx:for="{{categories}}" wx:key="*this">
      <view
        class="category-chip {{activeCategory === item ? 'category-chip-active' : ''}}"
        bindtap="switchCategory"
        data-category="{{item}}"
      >
        {{item}}
      </view>
    </block>
  </view>

  <block wx:for="{{visibleItems}}" wx:key="id">
    <view class="card item-card">
      <view class="row-between">
        <view class="item-name">{{item.name}}</view>
        <view class="item-category">{{item.category}}</view>
      </view>
      <view class="item-desc">{{item.description}}</view>
      <view class="item-recommend">推荐玩法：{{item.recommend}}</view>
      <view class="tag-row">
        <block wx:for="{{item.tags}}" wx:key="*this">
          <text class="tag">{{item}}</text>
        </block>
      </view>
    </view>
  </block>
</view>
