<view class="page">
  <view wx:if="{{loading}}" class="card hero-card">
    <view class="skeleton-block" style="height:320rpx;"></view>
    <view class="skeleton-block" style="height:36rpx;width:140rpx;margin-top:20rpx;"></view>
    <view class="skeleton-block" style="height:60rpx;width:480rpx;margin-top:20rpx;"></view>
    <view class="skeleton-block" style="height:24rpx;width:200rpx;margin-top:10rpx;"></view>
    <view class="skeleton-block" style="height:44rpx;width:560rpx;margin-top:14rpx;"></view>
    <view class="skeleton-block" style="height:20rpx;width:420rpx;margin-top:14rpx;"></view>
    <view style="display:flex;gap:16rpx;margin-top:20rpx;">
      <view class="skeleton-block" style="width:180rpx;height:128rpx;"></view>
      <view class="skeleton-block" style="width:180rpx;height:128rpx;"></view>
      <view class="skeleton-block" style="width:180rpx;height:128rpx;"></view>
      <view class="skeleton-block" style="width:180rpx;height:128rpx;"></view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="section-spacing">
    <view class="section-title">看点提要</view>
    <view class="card">
      <view class="skeleton-block" style="height:22rpx;width:520rpx;margin-top:14rpx;"></view>
      <view class="skeleton-block" style="height:22rpx;width:480rpx;margin-top:14rpx;"></view>
      <view class="skeleton-block" style="height:22rpx;width:500rpx;margin-top:14rpx;"></view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="section-spacing">
    <view class="section-title">智能讲解</view>
    <view class="card audio-card">
      <view class="skeleton-block" style="height:32rpx;width:180rpx;"></view>
      <view class="skeleton-block" style="height:24rpx;width:200rpx;margin-top:10rpx;"></view>
      <view class="skeleton-block" style="height:40rpx;width:560rpx;margin-top:14rpx;"></view>
      <view style="display:flex;gap:16rpx;margin-top:22rpx;">
        <view class="skeleton-block" style="flex:1;height:56rpx;"></view>
        <view class="skeleton-block" style="flex:1;height:56rpx;"></view>
      </view>
    </view>
    <view class="card guide-paragraph" style="margin-top:18rpx;">
      <view class="skeleton-block" style="height:20rpx;width:100rpx;margin-bottom:10rpx;"></view>
      <view class="skeleton-block" style="height:22rpx;width:560rpx;"></view>
      <view class="skeleton-block" style="height:22rpx;width:480rpx;margin-top:8rpx;"></view>
    </view>
    <view class="card guide-paragraph" style="margin-top:18rpx;">
      <view class="skeleton-block" style="height:20rpx;width:100rpx;margin-bottom:10rpx;"></view>
      <view class="skeleton-block" style="height:22rpx;width:560rpx;"></view>
      <view class="skeleton-block" style="height:22rpx;width:440rpx;margin-top:8rpx;"></view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="section-spacing">
    <view class="section-title">游览提示</view>
    <view class="card">
      <view class="skeleton-block" style="height:22rpx;width:500rpx;margin-top:14rpx;"></view>
      <view class="skeleton-block" style="height:22rpx;width:460rpx;margin-top:14rpx;"></view>
    </view>
  </view>

  <view wx:if="{{!loading && scenicSpot}}">
    <view class="card hero-card">
      <image class="spot-image card-img-top" src="{{scenicSpot.image}}" mode="aspectFill" bindtap="previewGallery" data-current="{{scenicSpot.image}}" lazy-load="{{true}}" />
      <view class="row-between">
        <view class="spot-category">{{scenicSpot.category}}</view>
        <view class="favorite-button" bindtap="toggleFavorite">{{isFavorite ? '已收藏' : '收藏景点'}}</view>
      </view>
      <view class="spot-name-row">
        <view class="spot-name">{{scenicSpot.name}}</view>
        <view class="spot-audio-meta">{{scenicSpot.audioMeta.narrator}} · {{scenicSpot.audioMeta.duration}}</view>
      </view>
      <view class="spot-summary">{{scenicSpot.summary}}</view>
      <view class="spot-meta">建议停留：{{scenicSpot.duration}} | 所在线索：{{scenicSpot.location}}</view>
      <scroll-view class="gallery-scroll" scroll-x="true" show-scrollbar="false">
        <view class="gallery-row">
          <block wx:for="{{gallery}}" wx:key="*this">
            <image class="gallery-thumb" src="{{item}}" mode="aspectFill" bindtap="previewGallery" data-current="{{item}}" />
          </block>
        </view>
      </scroll-view>
    </view>

    <view class="section-spacing">
      <view class="section-title">看点提要</view>
      <view class="card">
        <block wx:for="{{scenicSpot.highlights}}" wx:key="*this">
          <view class="bullet-item">{{item}}</view>
        </block>
      </view>
    </view>

    <view class="section-spacing">
      <view class="section-title">智能讲解</view>
      <view class="card audio-card">
        <view class="row-between">
          <view class="audio-title">音频讲解</view>
          <view class="audio-progress">{{audioProgress}}%</view>
        </view>
        <view class="audio-time">{{currentTimeText}} / {{durationText}}</view>
        <view class="audio-desc" wx:if="{{audioMode === 'audio'}}">当前景点已接入真实音频，可直接播放讲解。</view>
        <view class="audio-desc" wx:else>当前景点暂未接入音频文件，先以讲解文稿分段播放演示替代，后续可直接切换为真实音频。</view>
        <view class="audio-actions">
          <view class="audio-button audio-button-primary" bindtap="toggleAudioGuide">
            {{isAudioPlaying ? '暂停讲解' : '播放讲解'}}
          </view>
          <view class="audio-button" bindtap="nextParagraph">下一段</view>
        </view>
      </view>
      <block wx:for="{{scenicSpot.audioGuide}}" wx:key="*this" wx:for-index="index">
        <view class="card guide-paragraph {{activeAudioIndex === index ? 'guide-paragraph-active' : ''}}">
          <view class="paragraph-index">第{{index + 1}}段</view>
          <view>{{item}}</view>
        </view>
      </block>
    </view>

    <view class="section-spacing">
      <view class="section-title">游览提示</view>
      <view class="card">
        <block wx:for="{{scenicSpot.tips}}" wx:key="*this">
          <view class="bullet-item">{{item}}</view>
        </block>
      </view>
    </view>
  </view>
</view>
