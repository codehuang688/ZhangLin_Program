<view class="container">
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">
      <text class="title-text">随机景点</text>
    </view>
    <view class="header-right" bindtap="refresh">
      <text class="refresh-icon">🔄</text>
    </view>
  </view>

  <view class="sub-title">随机发现 · 探索古港</view>

  <view class="cards-container">
    <view class="card" wx:for="{{randomAttractions}}" wx:key="index" bindtap="showDetail" data-index="{{index}}">
      <view class="card-image-wrapper">
        <image class="card-image" src="{{item.image}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" />
        <view class="card-overlay">
          <view class="card-tag">{{item.category}}</view>
        </view>
        <view class="card-glow"></view>
      </view>
      <view class="card-content">
        <view class="card-title">{{item.name}}</view>
        <view class="card-description">{{item.description}}</view>
        <view class="card-footer">
          <view class="card-location">
            <text class="location-icon">📍</text>
            <text>{{item.location}}</text>
          </view>
          <view class="card-action">
            <text>查看详情 ›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="refresh-hint" bindtap="refresh">
    <text class="hint-icon">🔀</text>
    <text>点击刷新，发现更多景点</text>
  </view>

  <view class="modal" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{selectedAttraction.name}}</text>
        <text class="modal-close" bindtap="closeModal">×</text>
      </view>
      <view class="modal-image-wrapper">
        <image class="modal-image" src="{{selectedAttraction.image}}" mode="aspectFill" />
      </view>
      <view class="modal-body">
        <view class="modal-category">{{selectedAttraction.category}}</view>
        <view class="modal-location">
          <text class="location-icon">📍</text>
          <text>{{selectedAttraction.location}}</text>
        </view>
        <view class="modal-description">{{selectedAttraction.detail}}</view>
      </view>
    </view>
  </view>
</view>