.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a0f0a 0%, #0d0a08 50%, #1a0f0a 100%);
  padding-bottom: 60rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
}

.header-left {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
}

.header-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.title-icon {
  font-size: 36rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.header-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #d4a574 0%, #c19660 100%);
  border-radius: 50%;
  box-shadow: 0 4rpx 20rpx rgba(212, 165, 116, 0.4);
}

.refresh-icon {
  font-size: 32rpx;
}

.sub-title {
  text-align: center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  margin-bottom: 30rpx;
}

.cards-container {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
}

.card:active {
  transform: scale(0.98);
}

.card-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-overlay {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
}

.card-tag {
  padding: 8rpx 20rpx;
  background: rgba(212, 165, 116, 0.9);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.card-glow {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(0deg, rgba(26, 15, 10, 0.9) 0%, transparent 100%);
  pointer-events: none;
}

.card-content {
  padding: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.card-description {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.location-icon {
  font-size: 20rpx;
}

.card-action {
  font-size: 24rpx;
  color: #d4a574;
  font-weight: 500;
}

.refresh-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 40rpx;
  padding: 24rpx;
  background: rgba(212, 165, 116, 0.1);
  border-radius: 40rpx;
  margin-left: 30rpx;
  margin-right: 30rpx;
}

.refresh-hint:active {
  background: rgba(212, 165, 116, 0.2);
}

.hint-icon {
  font-size: 28rpx;
}

.refresh-hint text {
  font-size: 26rpx;
  color: #d4a574;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(10px);
}

.modal-content {
  width: 90%;
  max-height: 85vh;
  background: linear-gradient(180deg, #2d1810 0%, #1a0f0a 100%);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.modal-close {
  font-size: 52rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1;
}

.modal-image-wrapper {
  width: 100%;
  height: 360rpx;
}

.modal-image {
  width: 100%;
  height: 100%;
}

.modal-body {
  padding: 30rpx;
  max-height: 40vh;
  overflow-y: auto;
}

.modal-category {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(212, 165, 116, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #d4a574;
  margin-bottom: 16rpx;
}

.modal-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
}

.modal-description {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
}