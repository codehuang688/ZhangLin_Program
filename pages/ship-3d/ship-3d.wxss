.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a0f0a 0%, #2d1810 100%);
  padding-bottom: 40rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
}

.header-left {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
}

.header-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.title-icon {
  font-size: 36rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.header-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #d4a574 0%, #c19660 100%);
  border-radius: 16rpx;
}

.label-3d {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.sub-title {
  text-align: center;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  margin-bottom: 30rpx;
}

.model-container {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.model-wrapper {
  width: 100%;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

.ship-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.swipe-hint {
  text-align: center;
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
  margin-top: 20rpx;
}

.rotation-indicator {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.indicator-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 40rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #d4a574 0%, #c19660 100%);
}

.info-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.info-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-card:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.12);
}

.card-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 4rpx;
}

.card-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.card-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.4);
}

.detail-section, .features-section {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.section-icon {
  font-size: 28rpx;
}

.story-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.8;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.feature-icon {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.feature-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-height: 70vh;
  background: linear-gradient(180deg, #2d1810 0%, #1a0f0a 100%);
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.modal-close {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.modal-body text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.8;
}