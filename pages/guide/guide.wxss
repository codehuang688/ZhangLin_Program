/* ===== 智慧地图卡片 ===== */
.guide-map-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.map-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
}

.map-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3a2a21;
}

.map-subtitle {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #9a7b5f;
}

.map-locate-btn {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #f5ebe0;
  color: #8b3a1a;
  font-size: 22rpx;
  border: 1rpx solid rgba(180, 140, 100, 0.2);
}

.map-legend {
  display: flex;
  gap: 32rpx;
  padding: 16rpx 28rpx;
  border-top: 1rpx solid rgba(180, 140, 100, 0.1);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 20rpx;
  color: #8a7562;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #8b3a1a;
  border: 2rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(139, 58, 26, 0.3);
}

.legend-line {
  width: 30rpx;
  height: 4rpx;
  background: #c89050;
  border-radius: 2rpx;
}

/* ===== AI 推荐卡片 ===== */
.ai-rec-card {
  background: linear-gradient(135deg, rgba(30,10,6,0.93), rgba(50,20,10,0.9));
  border: 1rpx solid rgba(200, 160, 120, 0.15);
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

.ai-rec-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200,144,80,0.1), transparent);
  pointer-events: none;
}

.ai-rec-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.ai-rec-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 8rpx rgba(74, 222, 128, 0.5);
  animation: pulse 2s ease-in-out infinite;
}

.ai-rec-label {
  font-size: 22rpx;
  color: rgba(200, 160, 120, 0.8);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.ai-rec-body {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.ai-rec-icon {
  font-size: 32rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

.ai-rec-text {
  font-size: 24rpx;
  color: rgba(255, 240, 220, 0.78);
  line-height: 1.7;
}

/* ===== 路线标签 ===== */
.route-tabs {
  margin-bottom: 20rpx;
  white-space: nowrap;
}

.route-tab-wrap {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 4rpx;
}

.route-tab {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #fff3e8;
  color: #8a5a3d;
  font-size: 24rpx;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.route-tab-active {
  background: linear-gradient(135deg, #8b3a1a, #a34d2e);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(139, 58, 26, 0.25);
}

/* ===== 路线摘要卡片 ===== */
.route-summary {
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #fdf8f3, #fff);
  border: 1rpx solid rgba(200, 155, 110, 0.1);
}

.route-summary-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #3a2a21;
}

.route-duration-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #8b3a1a;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.route-meta-row {
  display: flex;
  gap: 28rpx;
  margin-top: 16rpx;
}

.route-meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #6f6156;
}

.meta-icon {
  font-size: 24rpx;
}

.route-description {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #7a6552;
  line-height: 1.7;
}

/* ===== 语音导览卡片 ===== */
.voice-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, #fef9f3, #fff5ec);
  border: 1rpx solid rgba(200, 150, 100, 0.18);
}

.voice-content {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.voice-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b3a1a, #c89050);
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-icon {
  font-size: 30rpx;
}

.voice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #3a2a21;
}

.voice-sub {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #9a7b5f;
}

.voice-play-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b3a1a, #c89050);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 58, 26, 0.25);
}

/* ===== 时间轴可视化 ===== */
.timeline-container {
  padding-left: 40rpx;
}

.timeline-row {
  display: flex;
  gap: 0;
  position: relative;
}

.timeline-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 56rpx;
  flex-shrink: 0;
  margin-left: -40rpx;
  position: relative;
}

.timeline-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b3a1a, #c89050);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(139, 58, 26, 0.3);
  z-index: 1;
}

.timeline-line {
  width: 3rpx;
  flex: 1;
  min-height: 40rpx;
  background: linear-gradient(to bottom, #c89050, rgba(200, 144, 80, 0.15));
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.timeline-card {
  flex: 1;
  margin-left: 20rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 252, 247, 0.95);
  border: 1rpx solid rgba(200, 155, 110, 0.08);
}

.timeline-card:last-child {
  margin-bottom: 0;
}

.stop-time {
  font-size: 22rpx;
  color: #8b3a1a;
  font-weight: 600;
}

.stop-title {
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #3a2a21;
}

.stop-detail {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #6f6156;
  line-height: 1.7;
}

.stop-walk {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(200, 150, 100, 0.2);
  font-size: 20rpx;
  color: #9a7b5f;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.walk-icon {
  font-size: 22rpx;
}

/* ===== 附近服务 ===== */
.service-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.service-item {
  text-align: center;
  padding: 20rpx 10rpx;
  background: rgba(255, 252, 247, 0.9);
}

.service-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.service-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #3a2a21;
}

.service-dist {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #9a7b5f;
}

/* ===== 游玩建议 ===== */
.tip-card {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.tip-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: #f5ebe0;
  color: #8b3a1a;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  line-height: 1.8;
  font-size: 23rpx;
  color: #5a4a3a;
  word-break: break-all;
  white-space: normal;
}

/* ===== 底部弹窗面板 ===== */
.stop-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.stop-detail-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.stop-detail-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.stop-detail-panel.show {
  transform: translateY(0);
}

.panel-handle {
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #d4c5b0;
  margin: 0 auto 20rpx;
}

.panel-stop-time {
  font-size: 22rpx;
  color: #8b3a1a;
  font-weight: 600;
}

.panel-stop-title {
  margin-top: 6rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #3a2a21;
}

.panel-stop-detail {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6f6156;
  line-height: 1.8;
}

.panel-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.panel-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 14rpx;
  background: #f5ebe0;
  color: #8b3a1a;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(180, 140, 100, 0.2);
}

.panel-btn.primary {
  background: linear-gradient(135deg, #8b3a1a, #a34d2e);
  color: #fff;
  border: none;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}