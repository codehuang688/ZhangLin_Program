<view class="page">
  <view class="card intro-card">
    <view class="section-title">地域文化科普</view>
    <view class="section-subtitle">以更易理解的方式梳理樟林古港的海贸记忆、侨乡文脉与建筑审美</view>
  </view>

  <view class="topic-list">
    <block wx:for="{{cultureTopics}}" wx:key="id">
      <view
        class="topic-chip {{activeTopicId === item.id ? 'topic-chip-active' : ''}}"
        bindtap="switchTopic"
        data-id="{{item.id}}"
      >
        {{item.title}}
      </view>
    </block>
  </view>

  <view class="card topic-panel">
    <view class="topic-title">{{activeTopic.title}}</view>
    <view class="topic-intro">{{activeTopic.intro}}</view>
  </view>

  <block wx:for="{{activeTopic.sections}}" wx:key="*this">
    <view class="card paragraph-card">{{item}}</view>
  </block>

  <view class="section">
    <view class="section-title">延伸提示</view>
    <block wx:for="{{activeTopic.facts}}" wx:key="*this">
      <view class="card fact-card">{{item}}</view>
    </block>
  </view>
</view>
