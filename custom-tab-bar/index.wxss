.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 100rpx;
  padding-bottom: 20rpx;
  background: rgba(255, 252, 247, 0.95);
  border-top: 1rpx solid rgba(180, 140, 100, 0.15);
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1;
  transition: transform 0.25s ease;
}

.tab-item.active .tab-icon {
  transform: scale(1.1);
}

.tab-text {
  font-size: 22rpx;
  color: #7c6f64;
  margin-top: 4rpx;
  line-height: 1.2;
}

.tab-item.active .tab-text {
  color: #8b3a1a;
  font-weight: 600;
}